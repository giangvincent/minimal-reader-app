{
  "name": "minimal-reader",
  "version": "0.1.0",
  "description": "A minimal reader for macOS and web.",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "electron": "electron .",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "epubjs": "0.3.93",
    "mammoth": "^1.8.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "playwright": "^1.57.0",
    "wait-on": "^8.0.1"
  },
  "overrides": {
    "@xmldom/xmldom": "0.8.13"
  },
  "build": {
    "appId": "com.minimalreader.app",
    "productName": "Minimal Reader",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
